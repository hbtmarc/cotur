{
  "rules": {
    ".read": false,
    ".write": false,

    "presentations": {
      ".read": true,
      ".write": "auth != null"
    },

    "admins": {
      ".read": "auth != null",
      ".write": false
    },

    "rotaDeGastos": {
      ".read": true,
      ".write": true,
      "meta": {
        ".read": true,
        ".write": true
      },
      "trips": {
        ".read": true,
        ".write": true,
        ".indexOn": ["createdAt", "updatedAt"]
      }
    },

    "users": {
      "$uid": {
        ".read":  "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    "documents": {
      ".indexOn": ["ownerUid"],
      ".read":  "auth != null && query.orderByChild === 'ownerUid' && query.equalTo === auth.uid",
      "$documentId": {
        ".read":  "auth != null && data.child('ownerUid').val() === auth.uid || data.child('status').val() === 'publicado'",
        ".write": "auth != null && (
                    !data.exists() ||
                    data.child('ownerUid').val() === auth.uid
                  )"
      }
    },
    "documentSections": {
      "$documentId": {
        ".indexOn": ["order"],
        ".read":  "auth != null && root.child('documents').child($documentId).child('ownerUid').val() === auth.uid || root.child('documents').child($documentId).child('status').val() === 'publicado'",
        ".write": "auth != null && root.child('documents').child($documentId).child('ownerUid').val() === auth.uid"
      }
    },
    "documentBlocks": {
      "$documentId": {
        "$sectionId": {
          ".indexOn": ["order"],
          ".read":  "auth != null && root.child('documents').child($documentId).child('ownerUid').val() === auth.uid || root.child('documents').child($documentId).child('status').val() === 'publicado'",
          ".write": "auth != null && root.child('documents').child($documentId).child('ownerUid').val() === auth.uid"
        }
      }
    },
    "documentHistory": {
      "$documentId": {
        ".indexOn": ["timestamp"],
        ".read":  "auth != null && root.child('documents').child($documentId).child('ownerUid').val() === auth.uid",
        ".write": "auth != null && root.child('documents').child($documentId).child('ownerUid').val() === auth.uid"
      }
    }
  }
}
